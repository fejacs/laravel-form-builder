{
    "name": "kris/laravel-form-builder",
    "description": "Laravel form builder - symfony like",
    "keywords": ["laravel", "form", "builder", "symfony"],
    "license": "MIT",
    "require": {
        "php": "^8.2 || ^8.3",
        "rdx/laravelcollective-html": "^6",
        "illuminate/support": "^10 || ^11 || ^12 || ^13",
        "illuminate/view": "^10 || ^11 || ^12 || ^13",
        "illuminate/http": "^10 || ^11 || ^12 || ^13",
        "illuminate/database": "^10 || ^11 || ^12 || ^13",
        "illuminate/validation": "^10 || ^11 || ^12 || ^13"
    },
    "require-dev": {
        "orchestra/testbench": "^10 || ^11",
        "phpunit/phpunit": "^10 || ^11 || ^12"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Kris\\LaravelFormBuilder\\FormBuilderServiceProvider"
            ],
            "aliases": {
                "FormBuilder": "Kris\\LaravelFormBuilder\\Facades\\FormBuilder"
            }
        }
    },
    "autoload": {
        "psr-4": {
            "Kris\\LaravelFormBuilder\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
